GOOGLE_MAPS_API_KEY=
OPEN_WEATHER_API_KEY=

# tools.crrm.dev — web app
# Long random string used to sign session cookies.
SESSION_SECRET=change-me-to-a-long-random-string

# Shared password gating protected tools (e.g. CC Analyzer).
TOOLS_PASSWORD=

# Service account credentials for Google Sheets access.
# Provide ONE of the following (resolved in this order):
#   1. GOOGLE_SERVICE_ACCOUNT_JSON      — raw JSON string
#   2. GOOGLE_SERVICE_ACCOUNT_JSON_B64  — base64-encoded JSON (best for Vercel)
#   3. GOOGLE_SERVICE_ACCOUNT_FILE      — absolute path to a JSON file
# If none are set, the app falls back to ./google-service-account.json at the repo root.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_SERVICE_ACCOUNT_FILE=
